# --- TriageBot · variables de entorno ---
# Copia este archivo a .env y rellena el valor.
# .env NUNCA se commitea (debe estar en .gitignore).

# API key de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=" Aquí va tu API key de OpenRouter"

# Secreto para firmar las cookies de sesión (login). Usa un valor largo y
# aleatorio en producción, p. ej.: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
